# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/?appName=child-vacc-system
MONGO_DB_NAME=child-vaccination-system

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URLs (CORS whitelist)
FRONTEND_URL=http://localhost:3000
PRODUCTION_URL=https://your-frontend-domain.com

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# Email Service Configuration (Gmail SMTP)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=your-gmail@gmail.com

# Firebase Configuration (Notification Service)
# These are used ONLY for optional Firebase notifications
# All business data remains in MongoDB
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_PRIVATE_KEY=your_private_key_json

# API Configuration
API_PREFIX=/api
